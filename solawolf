<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sola Sleepy Viewer</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background-color: #000000; }
        .viewer-container { width: 100vw; height: 100vh; background: #000000; }
        model-viewer { width: 100%; height: 100%; --poster-color: transparent; }
    </style>
</head>
<body>

    <div class="viewer-container">
        <model-viewer src="solawolf.glb" 
                      camera-controls 
                      auto-rotate 
                      shadow-intensity="2" 
                      shadow-softness="0.2"
                      exposure="0.45"
                      environment-image="neutral">
        </model-viewer>
    </div>

</body>
</html>
